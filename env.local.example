# Webhook ve API güvenlik anahtarları
ODOO_WEBHOOK_SECRET=buraya-gizli-odoo-webhook-anahtari
API_TOKEN=buraya-api-token

# Veritabanı bağlantı bilgileri (opsiyonel)
PORTAL_DB_URL=buraya-veritabani-url

# NextAuth yapılandırması
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=buraya-nextauth-gizli-anahtari

# E-posta gönderimi için SMTP ayarları (opsiyonel)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=kullanici@example.com
SMTP_PASSWORD=smtp-parola
SMTP_FROM=portal@campusglobal.com

# Loglama seviyesi
LOG_LEVEL=info

# Ortam
NODE_ENV=development 